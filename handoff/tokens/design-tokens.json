    "sm": {
      "$type": "dimension",
      "$value": "8px"
    },
    "md": {
      "$type": "dimension",
      "$value": "12px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "16px"
    },
    "xl": {
      "$type": "dimension",
      "$value": "24px"
    },
    "2xl": {
      "$type": "dimension",
      "$value": "32px"
    }
  },
  "radius": {
    "sm": {
      "$type": "dimension",
      "$value": "6px"
    },
    "md": {
      "$type": "dimension",
      "$value": "10px"
    },
    "lg": {
      "$type": "dimension",
      "$value": "14px"
    }
  },
  "font": {
    "size": {
      "xs": {
        "$type": "dimension",
        "$value": "12px"
      },
      "sm": {
        "$type": "dimension",
        "$value": "14px"
      },
      "md": {
        "$type": "dimension",
        "$value": "16px"
      },
      "lg": {
        "$type": "dimension",
        "$value": "20px"
      },
      "xl": {
        "$type": "dimension",
        "$value": "28px"
      }
    },
    "weight": {
      "regular": {
        "$type": "number",
        "$value": 400
      },
      "medium": {
        "$type": "number",
        "$value": 500
      },
      "semibold": {
        "$type": "number",
        "$value": 600
      },
      "bold": {
        "$type": "number",
        "$value": 700
      }
    }
  },
  "shadow": {
    "card": {
      "$type": "shadow",
      "$value": "0 1px 2px rgba(15, 23, 42, 0.06)"
    },
    "floating": {
      "$type": "shadow",
      "$value": "0 16px 40px rgba(15, 23, 42, 0.14)"
    }
  }
