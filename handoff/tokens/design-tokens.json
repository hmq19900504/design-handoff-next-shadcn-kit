{
  "meta": {
    "name": "DHP Merchant Risk Tokens",
    "version": "0.2.0",
    "format": "w3c-like"
  },
  "color": {
    "background": {
      "$type": "color",
      "$value": "#F8FAFC"
    },
    "surface": {
      "$type": "color",
      "$value": "#FFFFFF"
    },
    "surfaceMuted": {
      "$type": "color",
      "$value": "#F1F5F9"
    },
    "textPrimary": {
      "$type": "color",
      "$value": "#0F172A"
    },
    "textSecondary": {
      "$type": "color",
      "$value": "#64748B"
    },
    "border": {
      "$type": "color",
      "$value": "#E2E8F0"
    },
    "primary": {
      "$type": "color",
      "$value": "#2563EB"
    },
    "success": {
      "$type": "color",
      "$value": "#16A34A"
    },
    "warning": {
      "$type": "color",
      "$value": "#D97706"
    },
    "danger": {
      "$type": "color",
      "$value": "#DC2626"
    },
    "info": {
      "$type": "color",
      "$value": "#0891B2"
    }
  },
  "spacing": {
    "xs": {
      "$type": "dimension",
      "$value": "4px"
