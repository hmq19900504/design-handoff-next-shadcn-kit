  "apiContract": {
    "name": "MerchantRiskConsoleAPI",
    "version": "0.2.0",
    "basePaths": {
      "hono": "http://localhost:8787",
      "fastapi": "http://localhost:8000"
    },
    "models": {
      "RiskItem": {
        "id": "string",
        "merchantName": "string",
        "riskLevel": "low | medium | high | critical",
        "riskTags": "string[]",
        "fulfillmentScore": "number",
        "source": "manual | model | complaint | audit",
        "owner": "string",
        "updatedAt": "string",
        "status": "pending | processing | resolved | rejected"
      },
      "Metric": {
        "label": "string",
        "value": "number | string",
        "delta": "string",
        "tone": "info | success | warning | danger"
      },
      "RiskQuery": {
        "keyword": "string",
        "riskLevel": "string",
        "source": "string",
        "dateRange": "string"
      },
      "DispositionRequest": {
        "riskId": "string",
        "action": "mark-safe | restrict | escalate",
        "reason": "string"
      }
    },
    "endpoints": [
      {
        "method": "GET",
        "path": "/health",
        "response": {
          "ok": "boolean"
        }
      },
      {
        "method": "GET",
        "path": "/api/handoff",
        "response": "DhpBundle"
      },
      {
        "method": "GET",
        "path": "/api/risk-items",
        "query": "RiskQuery",
        "response": "RiskItem[]"
      },
      {
        "method": "POST",
        "path": "/api/dispositions",
        "body": "DispositionRequest",
        "response": {
          "ok": "boolean",
          "message": "string"
        }
      }
    ]
  },
  "pages": [
    {
      "path": "pages/merchant-risk-dashboard.md",
      "title": "商户履约风险控制台",
      "markdown": "# 商户履约风险控制台\n\n## 页面目标\n\n帮助运营识别高风险商户，筛选风险来源，查看风险原因，并对风险对象执行处置动作。\n\n## Markdown 线框\n\n```mermaid\nflowchart TB\n  Page[商户履约风险控制台] --> Header[标题/说明/权限提示]\n  Page --> Filter[筛选区 FilterPanel]\n  Page --> Metrics[指标卡 MetricCardGroup]\n  Page --> Table[风险列表 RiskTable]\n  Table --> Sheet[详情抽屉 RiskDetailSheet]\n```\n\n```dhp-layout\n{\n  \"pageId\": \"merchant-risk-dashboard\",\n  \"route\": \"/\",\n  \"title\": \"商户履约风险控制台\",\n  \"layout\": {\n    \"type\": \"PageShell\",\n    \"tokens\": {\n      \"padding\": \"spacing.xl\",\n      \"gap\": \"spacing.lg\",\n      \"background\": \"color.background\"\n    },\n    \"children\": [\n      {\"id\": \"header\", \"component\": \"PageHeader\", \"height\": \"auto\"},\n      {\"id\": \"filter\", \"component\": \"FilterPanel\", \"columns\": 4},\n      {\"id\": \"metrics\", \"component\": \"MetricCardGroup\", \"columns\": {\"desktop\": 4, \"tablet\": 2, \"mobile\": 1}},\n      {\"id\": \"riskTable\", \"component\": \"RiskTable\", \"minWidth\": 960},\n      {\"id\": \"detail\", \"component\": \"RiskDetailSheet\", \"width\": 520}\n    ]\n  }\n}\n```\n\n```dhp-binding\n{\n  \"dataSources\": {\n    \"metrics\": \"GET /api/risk-items -> derive metrics\",\n    \"riskItems\": \"GET /api/risk-items\",\n    \"handoff\": \"GET /api/handoff\"\n  },\n  \"fields\": {\n    \"RiskTable.id\": \"RiskItem.id\",\n    \"RiskTable.merchantName\": \"RiskItem.merchantName\",\n    \"RiskTable.riskLevel\": \"RiskItem.riskLevel\",\n    \"RiskTable.riskTags\": \"RiskItem.riskTags\",\n    \"RiskTable.fulfillmentScore\": \"RiskItem.fulfillmentScore\",\n    \"RiskTable.source\": \"RiskItem.source\",\n    \"RiskTable.updatedAt\": \"RiskItem.updatedAt\",\n    \"RiskTable.status\": \"RiskItem.status\"\n  }\n}\n```\n\n```dhp-state-matrix\n{\n  \"states\": [\n    {\"name\": \"loading\", \"scope\": \"page\", \"ui\": \"骨架屏：筛选区 1 行，指标卡 4 张，表格 6 行\"},\n    {\"name\": \"empty\", \"scope\": \"RiskTable\", \"ui\": \"空态文案：暂无符合条件的风险对象；操作：清空筛选\"},\n    {\"name\": \"error\", \"scope\": \"page\", \"ui\": \"错误提示 + 重试按钮，不清空已有筛选条件\"},\n    {\"name\": \"no-permission\", \"scope\": \"RiskDetailSheet\", \"ui\": \"禁止展示处置按钮，仅显示权限提示\"},\n    {\"name\": \"success\", \"scope\": \"page\", \"ui\": \"展示真实列表和可执行操作\"}\n  ]\n}\n```\n\n```dhp-interaction\n{\n  \"interactions\": [\n    {\n      \"id\": \"filter-submit\",\n      \"trigger\": \"点击 查询 或修改筛选项后 debounce 300ms\",\n      \"precondition\": \"用户拥有 risk.read 权限\",\n      \"effect\": \"刷新 RiskTable 数据并重算 MetricCardGroup\",\n      \"failure\": \"进入 error 状态，保留上一次成功数据\"\n    },\n    {\n      \"id\": \"open-detail\",\n      \"trigger\": \"点击表格行或 查看 按钮\",\n      \"effect\": \"打开 RiskDetailSheet，展示当前 RiskItem 详情\"\n    },\n    {\n      \"id\": \"dispose-risk\",\n      \"trigger\": \"在详情抽屉点击 处置\",\n      \"precondition\": \"用户拥有 risk.write 权限\",\n      \"effect\": \"POST /api/dispositions，成功后更新行状态为 processing\"\n    }\n  ]\n}\n```\n\n```dhp-responsive\n{\n  \"breakpoints\": {\n    \"desktop\": \">= 1280px\",\n    \"tablet\": \"768px - 1279px\",\n    \"mobile\": \"< 768px\"\n  },\n  \"rules\": [\n    {\"target\": \"FilterPanel\", \"mobile\": \"垂直堆叠，查询按钮占满宽度\"},\n    {\"target\": \"MetricCardGroup\", \"tablet\": \"2 列\", \"mobile\": \"1 列\"},\n    {\"target\": \"RiskTable\", \"mobile\": \"保留关键列：商户、风险等级、状态、操作\"},\n    {\"target\": \"RiskDetailSheet\", \"mobile\": \"宽度 100vw\"}\n  ]\n}\n```\n",
      "blocks": [
        {
          "type": "dhp-layout",
          "json": {
            "pageId": "merchant-risk-dashboard",
            "route": "/",
            "title": "商户履约风险控制台",
            "layout": {
              "type": "PageShell",
              "tokens": {
                "padding": "spacing.xl",
                "gap": "spacing.lg",
                "background": "color.background"
              },
              "children": [
                {
                  "id": "header",
                  "component": "PageHeader",
                  "height": "auto"
                },
                {
                  "id": "filter",
                  "component": "FilterPanel",
                  "columns": 4
                },
                {
                  "id": "metrics",
                  "component": "MetricCardGroup",
                  "columns": {
                    "desktop": 4,
                    "tablet": 2,
                    "mobile": 1
                  }
                },
                {
                  "id": "riskTable",
                  "component": "RiskTable",
                  "minWidth": 960
                },
                {
                  "id": "detail",
                  "component": "RiskDetailSheet",
                  "width": 520
                }
              ]
            }
          }
        },
        {
          "type": "dhp-binding",
          "json": {
            "dataSources": {
              "metrics": "GET /api/risk-items -> derive metrics",
              "riskItems": "GET /api/risk-items",
              "handoff": "GET /api/handoff"
            },
            "fields": {
              "RiskTable.id": "RiskItem.id",
              "RiskTable.merchantName": "RiskItem.merchantName",
              "RiskTable.riskLevel": "RiskItem.riskLevel",
              "RiskTable.riskTags": "RiskItem.riskTags",
              "RiskTable.fulfillmentScore": "RiskItem.fulfillmentScore",
              "RiskTable.source": "RiskItem.source",
              "RiskTable.updatedAt": "RiskItem.updatedAt",
              "RiskTable.status": "RiskItem.status"
            }
          }
        },
        {
          "type": "dhp-state-matrix",
          "json": {
            "states": [
              {
                "name": "loading",
                "scope": "page",
                "ui": "骨架屏：筛选区 1 行，指标卡 4 张，表格 6 行"
              },
              {
                "name": "empty",
                "scope": "RiskTable",
                "ui": "空态文案：暂无符合条件的风险对象；操作：清空筛选"
              },
              {
                "name": "error",
                "scope": "page",
                "ui": "错误提示 + 重试按钮，不清空已有筛选条件"
              },
              {
                "name": "no-permission",
                "scope": "RiskDetailSheet",
                "ui": "禁止展示处置按钮，仅显示权限提示"
              },
              {
                "name": "success",
                "scope": "page",
                "ui": "展示真实列表和可执行操作"
              }
            ]
          }
        },
        {
          "type": "dhp-interaction",
          "json": {
            "interactions": [
              {
                "id": "filter-submit",
                "trigger": "点击 查询 或修改筛选项后 debounce 300ms",
                "precondition": "用户拥有 risk.read 权限",
                "effect": "刷新 RiskTable 数据并重算 MetricCardGroup",
                "failure": "进入 error 状态，保留上一次成功数据"
              },
              {
                "id": "open-detail",
                "trigger": "点击表格行或 查看 按钮",
                "effect": "打开 RiskDetailSheet，展示当前 RiskItem 详情"
              },
              {
                "id": "dispose-risk",
                "trigger": "在详情抽屉点击 处置",
                "precondition": "用户拥有 risk.write 权限",
                "effect": "POST /api/dispositions，成功后更新行状态为 processing"
              }
            ]
          }
        },
        {
          "type": "dhp-responsive",
          "json": {
            "breakpoints": {
              "desktop": ">= 1280px",
              "tablet": "768px - 1279px",
              "mobile": "< 768px"
            },
            "rules": [
              {
                "target": "FilterPanel",
                "mobile": "垂直堆叠，查询按钮占满宽度"
              },
              {
                "target": "MetricCardGroup",
                "tablet": "2 列",
                "mobile": "1 列"
              },
              {
                "target": "RiskTable",
                "mobile": "保留关键列：商户、风险等级、状态、操作"
              },
              {
                "target": "RiskDetailSheet",
                "mobile": "宽度 100vw"
              }
            ]
          }
        }
      ]
    }
  ],
  "components": [
    {
      "path": "components/filter-panel.md",
      "title": "FilterPanel",
      "markdown": "# FilterPanel\n\n```dhp-component\n{\n  \"name\": \"FilterPanel\",\n  \"responsibility\": \"承载风险列表筛选条件，并触发查询。\",\n  \"implementedBy\": [\"Card\", \"Input\", \"Select\", \"Button\"],\n  \"props\": {\n    \"value\": \"RiskQuery\",\n    \"loading\": \"boolean\",\n    \"onChange\": \"(next: RiskQuery) => void\",\n    \"onSubmit\": \"() => void\",\n    \"onReset\": \"() => void\"\n  },\n  \"fields\": [\n    {\"name\": \"keyword\", \"label\": \"商户/风险ID\", \"component\": \"Input\", \"placeholder\": \"输入商户名称或风险ID\"},\n    {\"name\": \"riskLevel\", \"label\": \"风险等级\", \"component\": \"Select\", \"options\": [\"全部\", \"低\", \"中\", \"高\", \"严重\"]},\n    {\"name\": \"source\", \"label\": \"风险来源\", \"component\": \"Select\", \"options\": [\"全部\", \"模型\", \"投诉\", \"人工\", \"稽核\"]},\n    {\"name\": \"dateRange\", \"label\": \"时间范围\", \"component\": \"Select\", \"options\": [\"近7天\", \"近30天\", \"本季度\"]}\n  ],\n  \"states\": [\"idle\", \"loading\", \"error\"],\n  \"a11y\": [\"所有输入项必须有 label\", \"查询按钮 loading 时 aria-busy=true\"]\n}\n```\n",
      "blocks": [
        {
          "type": "dhp-component",
          "json": {
            "name": "FilterPanel",
            "responsibility": "承载风险列表筛选条件，并触发查询。",
            "implementedBy": [
              "Card",
              "Input",
              "Select",
              "Button"
            ],
            "props": {
              "value": "RiskQuery",
              "loading": "boolean",
              "onChange": "(next: RiskQuery) => void",
              "onSubmit": "() => void",
              "onReset": "() => void"
            },
            "fields": [
              {
                "name": "keyword",
                "label": "商户/风险ID",
                "component": "Input",
                "placeholder": "输入商户名称或风险ID"
              },
              {
                "name": "riskLevel",
                "label": "风险等级",
                "component": "Select",
                "options": [
                  "全部",
                  "低",
                  "中",
                  "高",
                  "严重"
                ]
              },
              {
                "name": "source",
                "label": "风险来源",
                "component": "Select",
                "options": [
                  "全部",
                  "模型",
