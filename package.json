{
  "name": "design-handoff-next-shadcn-kit",
  "version": "0.2.0",
  "private": true,
  "description": "DHP: Design Handoff Protocol kit for Codex, Next.js, shadcn/ui, Hono and FastAPI.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dhp:validate": "node scripts/dhp-validate.mjs ./handoff",
    "dhp:build": "node scripts/dhp-build.mjs ./handoff",
    "dhp:sync": "node scripts/sync-web.mjs ./handoff ./apps/web/src/generated",
    "dhp:init": "node scripts/dhp-init.mjs",
    "skill:link": "node scripts/install-live-links.mjs",
    "skill:link:dry": "node scripts/install-live-links.mjs --dry-run",
    "test:skill-link": "node --test scripts/install-live-links.test.mjs",
    "tool:install": "node scripts/install-tooling.mjs",
    "tool:install:dry": "node scripts/install-tooling.mjs --dry-run",
    "tool:status": "node scripts/install-tooling.mjs --status",
    "test:tooling": "node --test scripts/codex-marketplace-lib.test.mjs",
    "version:show": "node scripts/version-info.mjs",
    "version:sync": "node scripts/version-sync.mjs",
    "version:sync:dry": "node scripts/version-sync.mjs --dry-run",
    "test:dhp-build": "node --test scripts/dhp-build-lib.test.mjs",
    "test:version": "node --test scripts/version-info.test.mjs",
    "test:version-sync": "node --test scripts/version-sync.test.mjs",
    "verify:offline": "node scripts/verify-offline.mjs",
    "web:dev": "npm run dev -w apps/web",
    "web:build": "npm run build -w apps/web",
    "api:hono:dev": "npm run dev -w apps/api-hono",
    "api:hono:build": "npm run build -w apps/api-hono",
    "typecheck": "npm run typecheck -w apps/web && npm run typecheck -w apps/api-hono",
    "build": "npm run dhp:validate && npm run dhp:build && npm run dhp:sync && npm run web:build",
    "publish:github": "bash scripts/publish-github.sh"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
